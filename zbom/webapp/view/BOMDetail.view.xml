<mvc:View
    controllerName="zbom.controller.BOMDetail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:form="sap.ui.layout.form"
    xmlns="sap.m">

    <Page title="BOM Detail" showNavButton="true" navButtonPress="onNavBack">

        <content>

            <!-- 🔹 HEADER -->
            <VBox class="sapUiSmallMargin">
                <Title text="Input Screen" level="H2" class="sapUiSmallMarginBottom"/>

                <form:SimpleForm
                    editable="false"
                    layout="ResponsiveGridLayout"
                    labelSpanL="3" labelSpanM="3"
                    emptySpanL="4" emptySpanM="4">

                    <form:content>

                        <Label text="Plant"/>
                        <Text text="{Plant}"/>

                        <Label text="Material"/>
                        <Text text="{Material}"/>

                        <Label text="Material Description"/>
                        <Text text="{MaterialDesc}"/>

                        <Label text="BOM Usage"/>
                        <Text text="{BomUsage}"/>

                        <Label text="Base Quantity"/>
                        <Text text="{BaseQty} {BaseUom}"/>

                        <Label text="Valid From"/>
                        <Text text="{
                            path: 'ValidFrom',
                            type: 'sap.ui.model.type.Date',
                            formatOptions: { style: 'medium' }
                        }"/>

                    </form:content>
                </form:SimpleForm>
            </VBox>

            <!-- 🔹 ITEMS -->
            <VBox class="sapUiSmallMarginTop">

                <Toolbar>
                    <Title text="Create Material BOM" level="H2"/>
                    <ToolbarSpacer/>
                    <Button text="Create" press="onCreateItem"/>
                </Toolbar>

                <Table id="itemTable" items="{to_Item}">

                    <columns>
                        <Column><Text text="Item No"/></Column>
                        <Column><Text text="Component"/></Column>
                        <Column><Text text="Qty"/></Column>
                        <Column><Text text="UOM"/></Column>
                    </columns>

                    <items>
                        <ColumnListItem>
                            <cells>
                                <Text text="{ItemNo}"/>
                                <Text text="{Component}"/>
                                <Text text="{Quantity}"/>
                                <Text text="{Uom}"/>
                            </cells>
                        </ColumnListItem>
                    </items>

                </Table>

            </VBox>

        </content>
    </Page>
</mvc:View>