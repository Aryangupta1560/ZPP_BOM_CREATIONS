<mvc:View
    controllerName="zbom.controller.BOMItem"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <Page title="Add BOM Items">

        <content>
            <VBox>

                <Input placeholder="Item Category" id="itemCat"/>
                <Input placeholder="Component" id="component"/>
                <Input placeholder="Quantity" id="qty"/>
                <Input placeholder="UOM" id="uom"/>

                <Button text="Add Item" press="onAddItem"/>

            </VBox>
        </content>

    </Page>
</mvc:View>