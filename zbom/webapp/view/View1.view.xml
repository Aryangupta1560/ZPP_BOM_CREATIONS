<mvc:View
    controllerName="zbom.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <Page title="BOM List">

        <customHeader>
            <Toolbar>
                <Title text="BOMs"/>
                <ToolbarSpacer/>
                <Button text="Create" press="onCreate"/>
            </Toolbar>
        </customHeader>

        <content>
            <Table items="{/ZC_BOM_HEADER}">
                <columns>
                    <Column><Text text="Plant"/></Column>
                    <Column><Text text="Material"/></Column>
                    <Column><Text text="Usage"/></Column>
                </columns>

                <items>
                    <ColumnListItem press="onSelect">
                        <cells>
                            <Text text="{Plant}"/>
                            <Text text="{Material}"/>
                            <Text text="{BomUsage}"/>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>

    </Page>
</mvc:View>