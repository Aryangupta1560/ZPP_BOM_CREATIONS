<mvc:View
    controllerName="zbom.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

<Page title="BOMs">

    <!-- 🔹 FILTER BAR -->
    <VBox class="sapUiSmallMargin">

        <HBox justifyContent="SpaceBetween">

            <HBox>
                <VBox class="sapUiTinyMarginEnd">
                    <Label text="Plant"/>
                    <Input id="plantFilter"/>
                </VBox>

                <VBox class="sapUiTinyMarginEnd">
                    <Label text="Material"/>
                    <Input id="materialFilter"/>
                </VBox>

                <VBox>
                    <Label text="BOM Usage"/>
                    <Input id="usageFilter"/>
                </VBox>
            </HBox>

            <Button text="Go" type="Emphasized" press="onSearch"/>
        </HBox>

    </VBox>

    <!-- 🔹 TOOLBAR -->
    <Toolbar>
        <Title text="BOMs"/>
        <ToolbarSpacer/>

        <Button text="Delete" type="Reject" press="onDelete"/>
        <Button text="Create" type="Emphasized" press="onCreate"/>
    </Toolbar>

    <!-- 🔹 TABLE -->
    <Table
        id="bomTable"
        mode="MultiSelect"
        items="{/ZC_BOM_HEADER}">

        <columns>
            <Column>
                <header><Text text="Plant"/></header>
            </Column>
            <Column>
                <header><Text text="Material"/></header>
            </Column>
            <Column>
                <header><Text text="Usage"/></header>
            </Column>
            <Column width="50px">
                <header><Text text=""/></header>
            </Column>
        </columns>

        <items>
            <ColumnListItem type="Navigation" press="onNavigate">

                <cells>
                    <Text text="{Plant}"/>
                    <Text text="{Material}"/>
                    <Text text="{BomUsage}"/>

                    <!-- 🔹 Arrow like RAP -->
                    <Button icon="sap-icon://navigation-right-arrow" type="Transparent"/>
                </cells>

            </ColumnListItem>
        </items>

    </Table>

</Page>
</mvc:View>