<mvc:View
    controllerName="zbom.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <Page id="pageBOMCreation3" title="Material BOM Creation" showNavButton="false" backgroundDesign="Standard">
        <customHeader>
            <Bar>
                <contentLeft>
                    <Title text="Material BOM Creation" level="H2" class="sapUiSmallMarginBegin"/>
                </contentLeft>
                <contentRight>
                    <Button icon="sap-icon://action" type="Emphasized" press=".onExecute"/>
                    <Button icon="sap-icon://copy" class="sapUiSmallMarginEnd"/>
                </contentRight>
            </Bar>
        </customHeader>

        <content>
            <!-- Padding gives the form some breathing room from the screen edges -->
            <VBox class="sapUiResponsiveContentPadding">
                
                <f:SimpleForm
                    id="inputForm3"
                    title="Input Screen"
                    editable="true"
                    layout="ResponsiveGridLayout"
                    labelSpanXL="3" labelSpanL="3" labelSpanM="4" labelSpanS="12"
                    adjustLabelSpan="false"
                    emptySpanXL="6" emptySpanL="5" emptySpanM="2" emptySpanS="0"
                    columnsXL="1" columnsL="1" columnsM="1"
                    singleContainerFullSize="false">
                    <f:content>
                        <Label text="Material" required="true"/>
                        <Input id="inpMaterial3" showValueHelp="true" valueHelpRequest=".onMaterialValueHelp"/>

                        <Label text="BOM Usage" required="true"/>
                        <Input id="inpBomUsage3" />

                        <Label text="Plant" required="true"/>
                        <Input id="inpPlant3" />
                    </f:content>
                </f:SimpleForm>

                <f:SimpleForm
                    id="copyFromForm3"
                    title="Copy From"
                    editable="true"
                    layout="ResponsiveGridLayout"
                    labelSpanXL="3" labelSpanL="3" labelSpanM="4" labelSpanS="12"
                    adjustLabelSpan="false"
                    emptySpanXL="6" emptySpanL="5" emptySpanM="2" emptySpanS="0"
                    columnsXL="1" columnsL="1" columnsM="1"
                    singleContainerFullSize="false">
                    <f:content>
                        <Label text="Material"/>
                        <Input id="inpCopyMaterial3" showValueHelp="true"/>

                        <Label text="Plant"/>
                        <Input id="inpCopyPlant3" />

                        <Label text="Alternative BOM"/>
                        <HBox alignItems="Center">
                            <Input id="inpCopyAltBom3" />
                            <Button icon="sap-icon://arrow-right" class="sapUiTinyMarginBegin"/>
                        </HBox>
                    </f:content>
                </f:SimpleForm>

            </VBox>
        </content>

        <footer>
            <OverflowToolbar>
                <ToolbarSpacer/>
                <Button text="Continue" type="Emphasized" press=".onContinue"/>
                <Button text="Cancel" press=".onCancel"/>
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>