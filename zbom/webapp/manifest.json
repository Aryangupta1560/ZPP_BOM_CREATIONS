{
  "_version": "1.80.0",
  "sap.app": {
    "id": "zbom",
    "type": "application",
    "title": "Material BOM Creation",
    "description": "SAPUI5 Application for BOM Management",
    "dataSources": {
      "mainService": {
        "uri": "/sap/opu/odata/sap/ZSB_BOM_CREATION/",
        "type": "OData",
        "settings": {
          "odataVersion": "2.0",
          "localUri": "localService/metadata.xml"
        }
      }
    }
  },

  "sap.ui": {
    "technology": "UI5",
    "fullWidth": true
  },
  "sap.ui5": {
    "flexEnabled": false,
    "rootView": {
      "viewName": "zbom.view.App",
      "type": "XML",
      "id": "app",
      "async": true
    },
    "dependencies": {
      "minUI5Version": "1.80.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.ui.layout": {},
        "sap.f": {},
        "sap.ui.comp": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "zbom.i18n.i18n"
        }
      },
      "headerModel": {
        "type": "sap.ui.model.json.JSONModel",
        "settings": {}
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "defaultBindingMode": "TwoWay",
          "useBatch": true
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "controlId": "app",
        "controlAggregation": "pages",
        "viewType": "XML",
        "viewPath": "zbom.view",
        "async": true
      },
      "routes": [
        {
          "name": "RouteView1",
          "pattern": "",
          "target": "TargetView1"
        },
        {
          "name": "RouteBOMItem",
          "pattern": "BOMItem",
          "target": "TargetBOMItem"
        }
      ],
      "targets": {
        "TargetView1": {
          "viewName": "View1",
          "viewLevel": 1
        },
        "TargetBOMItem": {
          "viewName": "BOMItem",
          "viewLevel": 2
        }
      }
    }
  }
}